{
    "manifest_version": 3,
    "name": "SyntaxMentor",
    "version": "2.8.0",
    "version_name": "2.8.0 Elite",
    "description": "Mentor ortográfico com Cloud Sync, Estatísticas, Auto-Detecção de Idioma e API Pública",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "contextMenus"
    ],
    "host_permissions": [
        "https://api.languagetool.org/*",
        "https://*.digisac.com.br/*",
        "https://*.digisac.io/*",
        "https://*.blip.ai/*",
        "https://*.take.io/*"
    ],
    "commands": {
        "ativar-extensao": {
            "suggested_key": {
                "default": "Alt+Shift+A",
                "windows": "Alt+Shift+A",
                "mac": "Alt+Shift+A",
                "chromeos": "Alt+Shift+A",
                "linux": "Alt+Shift+A"
            },
            "description": "Ativar SyntaxMentor no site atual"
        },
        "desativar-extensao": {
            "suggested_key": {
                "default": "Alt+Shift+D",
                "windows": "Alt+Shift+D",
                "mac": "Alt+Shift+D",
                "chromeos": "Alt+Shift+D",
                "linux": "Alt+Shift+D"
            },
            "description": "Desativar SyntaxMentor no site atual"
        }
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "js/background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["js/content.js"],
            "css": ["css/content.css"],
            "all_frames": true,
            "match_about_blank": true,
            "match_origin_as_fallback": true,
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "js/content.js",
                "css/content.css",
                "welcome.html",
                "js/offline-grammar.js",
                "js/sentiment-analysis.js",
                "js/export-reports.js",
                "js/public-api.js",
                "js/api-usage.js",
                "api-usage.html",
                "api-docs.html"
            ],
            "matches": ["<all_urls>"]
        }
    ]
}