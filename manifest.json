{
    "manifest_version": 3,
    "name": "SyntaxMentor",
    "version": "2.8.1",
    "version_name": "2.8.1",
    "description": "Mentor ortográfico com correção em tempo real e dicionário pessoal",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "contextMenus"
    ],
    "host_permissions": [
        "https://api.languagetool.org/*"
    ],
    "content_security_policy": {
        "extension_pages": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.languagetool.org; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
    },
    "commands": {
        "abrir-painel": {
            "suggested_key": {
                "default": "Alt+S",
                "windows": "Alt+S",
                "mac": "Alt+S",
                "chromeos": "Alt+S",
                "linux": "Alt+S"
            },
            "description": "Abrir/fechar painel de correções"
        },
        "ativar-extensao": {
            "suggested_key": {
                "default": "Alt+Shift+A",
                "windows": "Alt+Shift+A",
                "mac": "Alt+Shift+A",
                "chromeos": "Alt+Shift+A",
                "linux": "Alt+Shift+A"
            },
            "description": "Ativar SyntaxMentor no site atual"
        },
        "desativar-extensao": {
            "suggested_key": {
                "default": "Alt+Shift+D",
                "windows": "Alt+Shift+D",
                "mac": "Alt+Shift+D",
                "chromeos": "Alt+Shift+D",
                "linux": "Alt+Shift+D"
            },
            "description": "Desativar SyntaxMentor no site atual"
        },
        "corrigir-tudo": {
            "suggested_key": {
                "default": "Alt+Shift+S",
                "windows": "Alt+Shift+S",
                "mac": "Alt+Shift+S",
                "chromeos": "Alt+Shift+S",
                "linux": "Alt+Shift+S"
            },
            "description": "Corrigir todos os erros automaticamente"
        }
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "options.html",
    "background": {
        "service_worker": "js/background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": [
                "js/shared/texts.js",
                "js/shared/dom.js",
                "js/shared/storage.js",
                "js/content/00-state.js",
                "js/content/01-platform-utils.js",
                "js/content/02-editor-events.js",
                "js/content/03-page-review.js",
                "js/content/04-context-observers.js",
                "js/content/05-grammar-highlights.js",
                "js/content/06-corrections-stats.js",
                "js/content/07-ui-panel.js",
                "js/content/08-shortcuts-input.js",
                "js/content/09-messaging.js",
                "js/content/11-bootstrap.js"
            ],
            "css": [
                "css/content/00-bubble.css",
                "css/content/01-panel.css",
                "css/content/02-cards.css",
                "css/content/03-animations.css",
                "css/content/04-responsive.css",
                "css/content/05-dark.css"
            ],
            "all_frames": true,
            "match_about_blank": true,
            "match_origin_as_fallback": true,
            "run_at": "document_end"
        }
    ]
}
